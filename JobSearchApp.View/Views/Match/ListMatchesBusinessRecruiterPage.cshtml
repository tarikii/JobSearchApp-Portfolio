@using JobSearchApp.BusinessLogic.DTOs

@model IEnumerable<MatchDto>

    <style>
        .badge{
        background-color: #BCDBF7;
        color: #1d3e81;
        }
    </style>

@if (Model.Count() != 0)
{
    <div class="container" style="padding-left: 5px; padding-right: 5px;">
        <div class="row">
            @foreach (MatchDto m in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100" style="background-color: #f5f5f5; border: none; box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); border-radius: 8px;">
                        <div class="card-body">
                            <h2 class="card-title" style="color: #1d3e81;">@m.JobTitle</h2>
                            <p class="card-text" style="background-color: #e9ecef; padding: 10px; border-radius: 4px; color: #000;">
                                Nombre Candidato: @m.User.FirstName @m.User.LastName
                            </p>



                            <span class="badge badge-pill">@m.User.LinkedInUrl</span>
                            <span class="badge badge-pill">@m.User.PortfolioUrl</span>
                            <span class="badge badge-pill">@m.User.Location</span>
                            <span class="badge badge-pill">@m.User.Headline</span>
                            <span class="badge badge-pill ">@m.User.Email</span>
                            <span class="badge badge-pill ">@m.User.MobileNumber</span>
                            <br /><br/>

                            <h5 style="color: #1d3e81;">Acerca de</h5>
                            <p class="card-text shadow-sm" style="height: 150px; border-radius:
                                4px; padding: 10px;">@m.User.Summary</p>
                            <div class="d-flex justify-content-end">
                                <a class="btn btn-primary" asp-area="" asp-controller="Feedback" asp-action="FormNewFeedbackPage" asp-route-id="@m.ApplicationId" asp-route-page="match">Dar Feedback</a>
                             
                            </div>
                        </div>
                    </div>
                </div>
            }   
        </div>
    </div>
}
else
{
    <h1>Postulate a una oferta</h1>
}

