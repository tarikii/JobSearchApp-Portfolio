@using JobSearchApp.BusinessLogic.DTOs

@model IEnumerable<InterestDto>

<link rel="stylesheet" href="~/css/preference.css" type="text/css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/css/bootstrap.min.css">


<a asp-controller="Home" asp-action="HomeLoggedPage" style="margin-left: 0.5rem;">
    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
        <path style="color: #1F4D78;" fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
    </svg>
</a>

<div class="title-edit-container mb-4 ms-3 me-3">
    <h1>MIS INTERESES</h1>
    <a asp-controller="SeeAll" asp-action="ListOfSeeAllPage" style="width: 15%; margin-right: 6rem;" class="btn btn-primary">Ver Todo</a>
</div>

<div class="preference-tags ms-3 me-3">
    @foreach (var interest in Model)
    {
        <div class="tag">
            <!-- Display the interest text -->
            <span class="interest-text" data-id="@interest.InterestId">@interest.InterestText</span>

            <!-- Edit Form (initially hidden) -->
            <form class="edit-form" action="~/Interest/UpdateInterest" method="post" style="display:none;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="InterestId" value="@interest.InterestId" />
                <input type="text" name="InterestText" value="@interest.InterestText" required />
                <button type="submit" class="btn btn-link p-0">
                    <i class="fa fa-check save-icon" aria-hidden="true"></i>
                </button>
            </form>

            <!-- Delete Form -->
            <form action="~/Interest/DeleteInterest" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@interest.InterestId" />
                <button type="submit" class="btn btn-link p-0">
                    <i class="fa fa-times delete-icon ms-3" aria-hidden="true"></i>
                </button>
            </form>

            <!-- Edit Icon -->
            <i class="fa fa-pencil edit-icon ms-3" aria-hidden="true"></i>
        </div>
    }
</div>

<div class="input-container mt-5 ms-3 me-3">
    <h4 class="mb-3">Nombre Interés</h4>
    <form action="~/Interest/CreateInterest" method="post">
        <div class="mb-3">
            <input type="number" value="@ViewBag.UserId" id="UserId" name="UserId" class="form-control d-none" />
            <input type="text" name="InterestText" class="form-control" placeholder="Ingrese el interés" required>
        </div>
        <button type="submit" class="btn btn-primary mt-4">Añadir</button>
    </form>
</div>
<script type="text/javascript" src="~/js/editInterest.js"></script>
