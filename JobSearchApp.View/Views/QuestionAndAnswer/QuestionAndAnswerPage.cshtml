@using JobSearchApp.BusinessLogic.DTOs

@model IEnumerable<QuestionAnswerDto>

@{
    int? selectedQuestionId = ViewBag.SelectedQuestionId as int?;
}

<h2>Preguntas y Respuestas</h2>
<div class="container mt-5">
    <label for="questionSelect" class="form-label fw-bold">Selecciona una pregunta:</label>
    <select id="questionSelect" class="form-select mb-3">
        <option value="" selected disabled>Seleccione una pregunta</option>
        @foreach (var item in Model)
        {
            if (item.QuestionId == selectedQuestionId)
            {
                <option value="@item.QuestionId" data-answer="@item.Answer?.AnswerText" data-answer-id="@item.Answer?.AnswerId" selected="selected">
                    @item.QuestionText
                </option>
            }
            else
            {
                <option value="@item.QuestionId" data-answer="@item.Answer?.AnswerText" data-answer-id="@item.Answer?.AnswerId">
                    @item.QuestionText
                </option>
            }
        }
    </select>

    <form id="answerForm" action="" method="post">
        <div id="answerContainer" class="card">
            <div class="card-header bg-primary text-white">
                Respuesta
            </div>
            <div class="card-body">
                <input type="hidden" id="questionId" name="QuestionId" />
                <input type="hidden" id="answerId" name="AnswerId" />
                <textarea id="answerText" name="AnswerText" class="form-control" rows="4" readonly></textarea>
            </div>
            <div class="card-button text-end">
                <button type="button" id="actionButton" class="btn btn-primary me-3">Responder</button>
                <br />
                <br />
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const defaultAnswer = "No has respondido todavía a esta pregunta.";

        function updateForm(selectedOption) {
            const answerText = selectedOption.getAttribute('data-answer') || defaultAnswer;
            const answerId = selectedOption.getAttribute('data-answer-id');

            document.getElementById('answerText').value = answerText;
            document.getElementById('questionId').value = selectedOption.value;
            document.getElementById('answerId').value = answerId || ""; // Update answerId input
        }

        document.getElementById('questionSelect').addEventListener('change', function () {
            const selectedOption = this.options[this.selectedIndex];
            updateForm(selectedOption);
            document.getElementById('answerText').readOnly = true;
            document.getElementById('actionButton').textContent = selectedOption.getAttribute('data-answer-id') ? "Editar respuesta" : "Responder";
        });

        document.getElementById('actionButton').addEventListener('click', function () {
            const answerTextArea = document.getElementById('answerText');
            const isEditing = !answerTextArea.readOnly;
            const answerForm = document.getElementById('answerForm');
            const answerText = answerTextArea.value.trim();
            const answerId = document.getElementById('answerId').value;

            if (isEditing) {
                if (answerText !== "") {
                    answerForm.action = '@Url.Content("~/QuestionAndAnswer/UpdateAnswer")';
                } else {
                    answerForm.action = '@Url.Content("~/QuestionAndAnswer/CreateNewAnswer")';
                }
                answerForm.submit();
            } else {
                answerTextArea.readOnly = false;
                this.textContent = "Guardar respuesta";
            }
        });

        // Ensure correct answer is displayed if question was pre-selected
        document.addEventListener('DOMContentLoaded', function () {
            const selectedQuestionId = '@selectedQuestionId';
            if (selectedQuestionId) {
                const selectedOption = document.querySelector(`#questionSelect option[value='${selectedQuestionId}']`);
                if (selectedOption) {
                    updateForm(selectedOption);
                }
            }
        });
    </script>
}
