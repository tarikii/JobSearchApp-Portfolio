@{
}
<h1>Añadir Nueva Educación</h1>
<form action="~/Education/CreateNewEducation" method="post">
    <div class="container">
        <div class="row">
            <div class="col mb-3">
                <label>Centro Educativo</label>
                <input type="text" class="form-control" name="SchoolName">
            </div>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label>Título</label>
                <input type="text" class="form-control" name="Degree">
            </div>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label>Campo de Estudio</label>
                <input type="text" class="form-control" name="FieldOfStudy" >
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Fecha Inicio</label>
                <input type="date" class="form-control" name="StartDate" placeholder="Fecha Inicio">
            </div>
            <div class="col-md-6 mb-3">
                <label>Fecha Finalización</label>
                <input type="date" class="form-control" name="EndDate" placeholder="Fecha de Finalización">
            </div>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label>Actividades y Sociedades</label>
                <textarea class="form-control" name="ActivitiesAndSocieties"></textarea>
            </div>
        </div
        <div class="row">
            <div class="col mb-3">
                <label>Descripción</label>
                <textarea class="form-control" name="Description"></textarea>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </div>

</form>