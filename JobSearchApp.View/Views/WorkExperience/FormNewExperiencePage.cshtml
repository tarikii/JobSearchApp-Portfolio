@{
}
<h1>Añadir Nueva Experiencia Laboral</h1>
<form action="~/WorkExperience/CreateNewExperience" method="post">
    <div class="container">
        <div class="row">
            <div class="col mb-3">
                <label>Nombre de Compañia</label>
                <input type="text" class="form-control" name="CompanyName">
            </div>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label>Puesto de Trabajo</label>
                <input type="text" class="form-control" name="JobTitle">
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Fecha Inicio</label>
                <input type="date" class="form-control" name="StartDate" placeholder="Fecha Inicio">
            </div>
            <div class="col-md-6 mb-3">
                <label>Fecha Finalización</label>
                <input type="date" class="form-control" name="EndDate" placeholder="Fecha de Finalización">
            </div>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label>Descripción</label>
                <textarea class="form-control" name="Description"></textarea>
            </div>
        </div>
        <div class="row">
            <div class="col mb-3">
                <label>Ubicación</label>
                <textarea class="form-control" name="Location"></textarea>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </div>
</form>