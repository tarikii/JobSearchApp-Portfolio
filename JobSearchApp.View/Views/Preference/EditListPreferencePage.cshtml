@using JobSearchApp.BusinessLogic.DTOs

@model IEnumerable<UserPreferenceDto>

<link rel="stylesheet" href="~/css/preference.css" type="text/css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<div class="title-edit-container">
    <h1>MIS PREFERENCIAS</h1>
    <a asp-controller="SeeAll" asp-action="ListOfSeeAllPage" class="btn btn-primary">Ver Todo</a>
</div>

<div class="preference-tags">
    @foreach (var preference in Model)
    {
        <div class="tag">
            <!-- Display the interest text -->
            <span class="interest-text" data-id="@preference.PreferenceId">@preference.Value</span>

            <!-- Edit Form (initially hidden) -->
            <form class="edit-form" action="~/Preference/UpdatePreference" method="post" style="display:none;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PreferenceId" value="@preference.PreferenceId" />
                <input type="text" name="Value" value="@preference.Value" />
                <button type="submit" class="btn btn-link p-0">
                    <i class="fa fa-check save-icon" aria-hidden="true"></i>
                </button>
            </form>

            <!-- Delete Form -->
            <form action="~/Preference/DeletePreference" method="post" style="display:inline;">
                <input type="hidden" name="id" value="@preference.PreferenceId" />
                <button type="submit" class="btn btn-link p-0">
                    <i class="fa fa-times delete-icon ms-3" aria-hidden="true"></i>
                </button>
            </form>

            <!-- Edit Icon -->
            <i class="fa fa-pencil edit-icon ms-3" aria-hidden="true"></i>
        </div>
    }
</div>

<div class="input-container mt-5">
    <h4 style="color: #1F4D78; font-weight: bold;" class="mt-4">Nombre Preferencia</h4>
    <form action="~/Preference/CreatePreference" method="post">
        <div class="custom-form-group">
            <input type="number" value="@ViewBag.UserId" id="UserId" name="UserId" class="form-control" hidden />
            <input type="text" name="Value" class="custom-form-control" placeholder="Ingrese la preferencia">
        </div>
        <button type="submit" class="btn btn-primary mt-4">Añadir</button>
    </form>
</div>
<script type="text/javascript" src="~/js/editPreference.js"></script>
