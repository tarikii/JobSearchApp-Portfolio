@using JobSearchApp.BusinessLogic.DTOs

@model IEnumerable<UserPreferenceDto>

<link rel="stylesheet" href="~/css/preference.css" type="text/css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/css/bootstrap.min.css">

<a asp-controller="Home" asp-action="HomeLoggedPage" style="margin-left: 0.5rem;">
    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
        <path style="color: #1F4D78;" fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
    </svg>
</a>

<div class="title-edit-container mb-4 ms-3 me-3">
    <h1>MIS PREFERENCIAS</h1>
    <a asp-controller="SeeAll" asp-action="ListOfSeeAllPage" style="width: 15%; margin-right: 6rem;" class="btn btn-primary">Ver Todo</a>
</div>

<div class="preference-tags ms-3 me-3">
    @foreach (var preference in Model)
    {
        <div class="tag">
            <!-- Display the preference text -->
            <span class="interest-text" data-id="@preference.PreferenceId">@preference.Value</span>

            <!-- Edit Form (initially hidden) -->
            <form class="edit-form" action="~/Preference/UpdatePreference" method="post" style="display:none;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PreferenceId" value="@preference.PreferenceId" />
                <input type="text" name="Value" value="@preference.Value" required />
                <button type="submit" class="btn btn-link p-0">
                    <i class="fa fa-check save-icon" aria-hidden="true"></i>
                </button>
            </form>

            <!-- Delete Button with modal trigger -->
            <button type="button" class="btn btn-link p-0 delete-btn" data-id="@preference.PreferenceId" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                <i class="fa fa-times delete-icon ms-3" aria-hidden="true"></i>
            </button>

            <!-- Edit Icon -->
            <i class="fa fa-pencil edit-icon ms-3" aria-hidden="true"></i>
        </div>
    }
</div>

<div class="input-container mt-5 ms-3 me-3">
    <h4 class="mb-3">Nombre Preferencia</h4>
    <form action="~/Preference/CreatePreference" method="post">
        <div class="mb-3">
            <input type="number" value="@ViewBag.UserId" id="UserId" name="UserId" class="form-control d-none" />
            <input type="text" name="Value" class="form-control" placeholder="Ingrese la preferencia" required>
        </div>
        <button type="submit" class="btn btn-primary mt-4">Añadir</button>
    </form>
</div>

<!-- Bootstrap Modal for Confirmation -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmDeleteModalLabel">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de que deseas eliminar esta preferencia? Esta acción no se puede deshacer.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="confirmDeleteForm" method="post" class="d-inline">
                    <input type="hidden" name="id" id="deletePreferenceId" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/editPreference.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var deleteButtons = document.querySelectorAll('.delete-btn');

        deleteButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                var preferenceId = button.getAttribute('data-id');
                var confirmForm = document.getElementById('confirmDeleteForm');
                confirmForm.action = '/Preference/DeletePreference'; // Set the form action URL

                document.getElementById('deletePreferenceId').value = preferenceId;
            });
        });
    });
</script>
