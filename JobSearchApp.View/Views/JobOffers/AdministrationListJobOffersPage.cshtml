@model IEnumerable<JobSearchApp.BusinessLogic.DTOs.JobOfferDto>


<a asp-controller="Home" asp-action="HomeLoggedPage" style="margin-left: 1rem; display: inline-flex; align-items: center;">
    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
        <path style="color: #1F4D78;" fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
    </svg>
</a>

<link rel="stylesheet" href="~/css/jobOffer.css" type="text/css" />
<div style="margin-top: 1rem;" class="button-filter">
    <h1 style="margin-left: 1rem;">@ViewBag.Title</h1>
    <a style="margin-right: 1rem;" class="btn btn-primary" class="nav-link text-white" asp-area="" asp-controller="JobOffers" asp-action="FormNewJobOfferPage">Añadir Nueva</a>
</div>

<div class="job-offers">
    <!-- Repeat the .job-offer-card div for more offers -->
    @foreach (var jobOffer in Model)
    {

        <div style="margin-left: 2rem; margin-right: 2rem;" class="job-offer-card">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <h3>@jobOffer.Title</h3>
                @if (ViewBag.SearchCandidate == "False")
                {
                    <div style="display: flex; gap: 5px;">
                        <a class="btn btn-primary nav-link text-white" style="padding: 5px;" asp-area="" asp-controller="JobOffers" asp-action="FormModificationJobOfferPage" asp-route-id="@jobOffer.JobOfferId">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-fill" viewBox="0 0 16 16">
                                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z" />
                            </svg>
                        </a>
                        <form asp-area="" asp-controller="JobOffers" asp-action="DeleteJobOffer" method="post">
                            <input type="hidden" name="id" value="@jobOffer.JobOfferId" />
                            <a type="submit" class="btn btn-primary">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash-fill" viewBox="0 0 16 16">
                                    <path d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0" />
                                </svg>
                            </a>
                        </form>
                    </div>
                }
            </div>



            @if (ViewBag.SearchCandidate == "False")
            {
                <p>Fecha de creación: <span style="font-weight:200">@jobOffer.PostedDate.ToString("dd/MM/yyyy")</span></p>
            }
            <h5 style="font-weight:bold; color: #1F4D78;">Descripción</h5>
            <p style="font-weight:500">@jobOffer.Description</p>

            <div style="display: flex; justify-content: right; gap: 10px;">
                <a class="btn btn-primary nav-link text-white" asp-area="" asp-controller="JobOffers" asp-action="SaveJobOfferIdAndSearchCandidate" asp-route-id="@jobOffer.JobOfferId">Buscar Candidato</a>
                <a class="btn btn-primary nav-link text-white" asp-area="" asp-controller="JobOffers" asp-action="ListCandidatesPostulatedJobOfferPage" asp-route-id="@jobOffer.JobOfferId">Revisar candidatos postulados</a>
            </div>

        </div>



    }
    <!-- Add more job offer cards as needed -->
</div>
