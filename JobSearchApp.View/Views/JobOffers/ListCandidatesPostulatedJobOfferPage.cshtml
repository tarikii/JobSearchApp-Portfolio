@using JobSearchApp.BusinessLogic.DTOs
@model IEnumerable<ApplicationDto>

<div class="container my-4">
    <!-- Job Offer Section -->
    <div class="mb-4">
        <!-- Title Section -->
        <div style="background-color: #1f4d78; color: white; padding: 20px; border-radius: 5px 5px 0 0;">
            <h3 style="color: #fff; font-weight: bold;" class="mb-0">@Model.First().JobOffer.Title</h3>
        </div>
        <!-- Description Section -->
        <div style="background-color: #f5f5f5; padding: 20px; border-radius: 0 0 5px 5px;">
            <p  style="color: #000; font-weight: bold;" class="mb-0">Descripción: @Model.First().JobOffer.Description</p>
        </div>
    </div>

    <hr />

    <!-- Candidates Section -->
    <div class="mt-4">
        <h4>Candidatos</h4>
        <br />
        @foreach (ApplicationDto a in Model)
        {
            @if (a.User.Role.Name == "Candidato")
            {
                <div class="card mb-3" style="border: 1px solid #e0e0e0; background-color: #f5f5f5; border-radius: 5px;">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h3 style="font-weight: bold;" class="card-text" style="margin-bottom: 0;">@a.User.Headline</h3>
                            <br />
                            <p class="card-text" style="margin-bottom: 0;">@a.User.Summary</p>
                        </div>
                        <div>
                            <a class="btn btn-primary mr-2"
                               style="padding: 8px 16px;"
                               asp-area=""
                               asp-controller="Feedback"
                               asp-action="FormNewFeedbackPage"
                               asp-route-id="@a.ApplicationId">Dar feedback</a>
                            <a class="btn btn-danger" style="padding: 8px 16px;" asp-area=""
                               asp-controller="Home"
                               asp-action="HomePage">Ver perfil</a>
                        </div>
                    </div>
                </div>
                <br />
            }
        }
    </div>
</div>
