@using JobSearchApp.BusinessLogic.DTOs

@model IEnumerable<ApplicationDto>

<h1>Titulo Oferta: @Model.First().JobOffer.Title</h1>

<hr />

@foreach (ApplicationDto a in Model)
{
    <div class="d-flex align-items-center mb-3">
        <h1 class="mr-3">Candidato: @a.User.UserName</h1>
        <a class="btn btn-primary" asp-area="" asp-controller="Feedback" asp-action="FormNewFeedbackPage" asp-route-id="@a.ApplicationId">Dar Feedback</a>
        <a class="btn btn-danger" asp-area="" asp-controller="Home" asp-action="HomePage">Ver Perfil</a>
    </div>
}
