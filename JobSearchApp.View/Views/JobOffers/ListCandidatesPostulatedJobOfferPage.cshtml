@using JobSearchApp.BusinessLogic.DTOs
@model IEnumerable<ApplicationDto>

<a asp-controller="JobOffers" asp-action="AdministrationListJobOffersPage" style="margin-left: 3rem; display: inline-flex; align-items: center;">
    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
        <path style="color: #1F4D78;" fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
    </svg>
</a>

<h1 style="margin-left: 2rem;">Candidatos Postulados</h1>

<hr />

<div class="container my-4">

    <div class="mb-4">
        <!-- Title Section -->
        <div style="background-color: #1f4d78; color: white; padding: 20px; border-radius: 5px 5px 0 0;">
            <h3 style="color: #fff; font-weight: bold;" class="mb-0">@ViewBag.JobTitle</h3>
        </div>
        <!-- Description Section -->
        <div style="background-color: #f5f5f5; padding: 20px; border-radius: 0 0 5px 5px;">
            <p style="color: #000; font-weight: bold;" class="mb-0">Descripción: @ViewBag.JobDescription</p>
        </div>
    </div>

    <hr />
    <!-- Job Offer Section -->
    @if (Model.Any()) // Check if there are any elements in Model
    {
        <!-- Candidates Section -->
        <div class="mt-4">
            <h4>Candidatos</h4>
            <br />
            @foreach (ApplicationDto a in Model)
            {
                @if (a.User.Role.Name == "Candidato")
                {
                    <div class="card mb-3" style="border: 1px solid #e0e0e0; background-color: #f5f5f5; border-radius: 5px;">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h3 style="font-weight: bold;" class="card-text" style="margin-bottom: 0;">@a.User.Headline</h3>
                                <br />
                                <p class="card-text" style="margin-bottom: 0;">@a.User.Summary</p>
                            </div>
                            <div>
                                <a class="btn btn-primary mr-2"
                                   style="padding: 8px 16px;"
                                   asp-area=""
                                   asp-controller="Feedback"
                                   asp-action="FormNewFeedbackPage"
                                   asp-route-id="@a.ApplicationId">Dar feedback</a>
                            </div>
                        </div>
                    </div>
                    <br />
                }
            }
        </div>
    }
    else
    {

        <div class="card mb-3" style="border: 1px solid #e0e0e0; background-color: #f5f5f5; border-radius: 5px;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h3 style="font-weight: bold;" class="card-text" style="margin-bottom: 0;">No hay ningun candidato postulado</h3>
                </div>
            </div>
        </div>
    }
</div>
