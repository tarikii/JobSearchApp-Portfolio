@model JobSearchApp.BusinessLogic.DTOs.CreateJobOfferDto

<link rel="stylesheet" href="~/css/jobOffer.css" type="text/css" />
<h2>Nueva Oferta</h2>
<form asp-action="CreateNewJobOffer" method="post" class="job-offer-form">
    <div class="form-group">
        <label for="Title">Título Oferta</label>
        <input type="text" id="Title" name="Title" class="form-control" required />
    </div>

    <input type="number" value="@ViewBag.CompanyId" id="CompanyId" name="CompanyId" class="form-control" hidden />
  
    <div class="form-row">
        <div class="form-group col">
            <label for="Location">Ubicación</label>
            <input type="text" id="Location" name="Location" class="form-control" required />
        </div>
        <div class="form-group col">
            <label for="JobType">Tipo de Trabajo</label>
            <input type="text" id="JobType" name="JobType" class="form-control" required />
        </div>
    </div>
    <div class="form-row">
        <div class="form-group col">
            <label for="ExperienceLevel">Nivel de Experiencia</label>
            <input type="text" id="ExperienceLevel" name="ExperienceLevel" class="form-control" required />
        </div>
        <div class="form-group col">
            <label for="ExpiredDate">Fecha de Expiración</label>
            <input type="date" data-date-format="YYYY MMMM DD" id="ExpiredDate" name="ExpiredDate" class="form-control" />
        </div>
    </div>
    <div class="form-row">
        <div class="form-group col">
            <label for="MinSalary">Salario Mínimo</label>
            <input type="number" id="MinSalary" name="MinSalary" class="form-control" step="0.01" />
        </div>
        <div class="form-group col">
            <label for="MaxSalary">Salario Máximo</label>
            <input type="number" id="MaxSalary" name="MaxSalary" class="form-control" step="0.01" />
        </div>
    </div>
    <div class="form-group">
        <label for="Description">Descripción</label>
        <textarea style="height: 120px;" type="text" id="Description" name="Description" class="form-control desription-textarea" step="0.01"></textarea>
    </div>
    <div class="form-group button-container">
        <button type="submit" class="btn btn-primary">Crear</button>
    </div>
    <br />
</form>
