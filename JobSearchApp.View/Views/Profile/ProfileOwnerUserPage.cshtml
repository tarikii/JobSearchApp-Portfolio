@using JobSearchApp.BusinessLogic.DTOs
@using JobSearchApp.Domain.Models

@model UserDto

<div class="container mt-5">
    <div class="card p-3">
        <div class="row">
            <div class="col-2">
                <img src="https://via.placeholder.com/100" alt="Profile Image" class="rounded-circle mb-3">
                <h5 class="fw-bold mb-1">@Model.UserName</h5>
                <p class="text-muted">Titular</p>
            </div>
            <div class="col-10">
                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>Nombre:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;">Tu nombre aquí</div>
                </div>

                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>Apellidos:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;">Tus apellidos aquí</div>
                </div>

                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>Género:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; width: 75%;">Tu género aquí</div>
                </div>

                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>Ubicación:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;">Tu ubicación aquí</div>
                </div>

                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>LinkedIn:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; width: 75%;">Tu LinkedIn aquí</div>
                </div>

                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>Apodo:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;">Tu apodo aquí</div>
                </div>

                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>Teléfono:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;">Tu teléfono aquí</div>
                </div>

                <div style="display: flex; align-items: center; margin-bottom: 8px;">
                    <p style="margin: 0; width: 100px;"><strong>Correo:</strong></p>
                    <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;">Tu correo aquí</div>
                </div>

            </div>
        </div>
        <hr>
        <div>
            <h5 class="fw-bold mb-1">Descripción</h5>
            <div class="bg-secondary bg-opacity-25 rounded mb-2" style="height: 20px;"></div>
            <div class="bg-secondary bg-opacity-25 rounded mb-2" style="height: 20px; width: 75%;"></div>
        </div>
    </div>
</div>
</div>


