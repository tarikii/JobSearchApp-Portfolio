@using JobSearchApp.BusinessLogic.DTOs
@using JobSearchApp.Domain.Models

@model UserDto

<div class="container mt-5">
    <div class="card p-3">
        <div class="row position-relative">
            <div class="col-2">
                <img src="https://via.placeholder.com/100" alt="Profile Image" class="rounded-circle mb-3">
                <h5 class="fw-bold mb-1" id="UserName">@Model.UserName</h5>
                <p class="text-muted">Titular</p>
            </div>

            <div class="col-10">
                <button class="btn btn-primary position-absolute" style="top: 0; right: 0;margin-right:10px;" onclick="enableEditing()" id="button-edit">Editar</button>

                <form action="~/Profile/UpdateUserPersonalData" method="post">
                    <div id="edit-buttons" style="display: none; flex; justify-content: flex-end; position: absolute; top: 0; right: 0;">
                        <button type="submit" class="btn btn-primary" style="margin-right: 10px;">Confirmar</button>
                        <button class="btn btn-primary" onclick="edit2()">Cancelar</button>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Nombre:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;" id="FirstName">@Model.FirstName</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Apellidos:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;" id="LastName">@Model.LastName</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Género:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 75%;" id="GenderIdentity">@Model.GenderIdentity</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Ubicación:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;" id="Location">@Model.Location</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>LinkedIn:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 75%;" id="LinkedInUrl">@Model.LinkedInUrl</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Apodo:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;" id="Headline">@Model.Headline</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Teléfono:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;" id="MobileNumber">@Model.MobileNumber</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Correo:</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;" >@Model.Email</div>
                    </div>
                </form>
            </div>
        </div>

        <hr>
        <div>
            <h5 class="fw-bold mb-1">Descripción</h5>
            <div class="bg-opacity-25 rounded mb-2" style="height: 20px;" id="Summary">@Model.Summary</div>
        </div>
    </div>
</div>
</div>


