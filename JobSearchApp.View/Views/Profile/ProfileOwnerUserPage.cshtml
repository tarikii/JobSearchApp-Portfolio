@using JobSearchApp.BusinessLogic.DTOs
@using JobSearchApp.Domain.Models

@model UserDto

<a asp-controller="Home" asp-action="HomeLoggedPage" style="margin-left: 2rem;">
    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
        <path style="color: #1F4D78;" fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8" />
    </svg>
</a>
<h1 style="margin-left: 2rem;">Mi Perfil</h1>

<hr />

<div class="container mt-2">
    <form action="~/Profile/UpdateUserPersonalData" method="post">
        <div class="card p-3">
            <div class="row position-relative">
                <div class="col-2">
                    <img src="~/lib/img/perifl-icon.jpg" alt="Profile Image" class="rounded-circle mb-3" width="150" height="150">
                    <h5 class="fw-bold mb-1">@Model.UserName</h5>
                    <br />
                    <h6 style="font-weight: bold;">Título Profesional</h6>
                    <p class="fw-bold mb-1 text-muted" id="Headline">@Model.Headline</p>
                </div>

                <div class="col-10 position-relative">
                    <button type="button" class="btn btn-primary position-absolute" style="bottom: 0; right: 0; margin: 10px;" onclick="enableEditing()" id="button-edit">Editar</button>
                    <div id="edit-buttons" style="display: none; margin-top: 20px; position: absolute; right: 0; bottom: 0;">
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary me-2">Confirmar</button>
                            <a asp-controller="Profile" asp-action="ProfileOwnerUserPage" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </div>

                    <!-- User Information -->
                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Nombre</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;" id="FirstName">@Model.FirstName</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Apellidos</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;" id="LastName">@Model.LastName</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Género</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 75%;" id="GenderIdentity">@Model.GenderIdentity</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Ubicación</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; flex-grow: 1;" id="Location">@Model.Location</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>LinkedIn</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 75%;" id="LinkedInUrl">@Model.LinkedInUrl</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Teléfono</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;" id="MobileNumber">@Model.MobileNumber</div>
                    </div>

                    <div style="display: flex; align-items: center; margin-bottom: 8px;">
                        <p style="margin: 0; width: 100px;"><strong>Correo</strong></p>
                        <div class="bg-opacity-25 rounded" style="padding: 5px; width: 50%;">@Model.Email</div>
                    </div>
                </div>
            </div>

            <hr>
            <div>
                <h5 class="fw-bold mb-1">Descripción</h5>
                <div class="bg-opacity-25 rounded mb-2" style="height: 20px;" id="Summary">@Model.Summary</div>
            </div>
        </div>
    </form>
</div>

@if (Model.RoleName == "Reclutador" || Model.RoleName == "Candidato")
{

    @if (Model.Educations != null)
    {
        <div class="card container p-1" style="border-radius: 10px; margin-top: 3%; background-color: #F5F5F5;">
            <div class="d-flex justify-content-between align-items-center mb-2 mt-4">
                <h1 style="margin-left: 20px;">Educaciones📚</h1>
                <a class="btn btn-primary" style="margin-right:15px;" asp-area="" asp-controller="Education" asp-action="FormNewEducationPage">Añadir</a>
            </div>

            @foreach (Education edu in Model.Educations)
            {
                <div class="card row p-5 m-3" style=" border-radius: 10px;">
                    <div class="d-flex flex-column flex-md-row align-items-center">
                        <!-- Contenedor para el título y la descripción -->
                        <div class="flex-grow-1 mb-3 mb-md-0">
                            <h3 style="color: #1f4d78;" class="mb-0">Nombre del centro: @edu.SchoolName</h3>
                            <br />
                            <h5 class="mb-0">Descripción: @edu.Description </h5>
                            <br />
                            <p class="mb-0">Duración: De @edu.StartDate.ToString("yyyy-MM-dd") hasta @edu.EndDate.ToString("yyyy-MM-dd")</p>
                        </div>

                        <!-- Contenedor para los botones -->
                        <div class="ms-auto d-flex align-items-center">
                            <a class="btn btn-primary me-2" asp-area="" asp-controller="Education" asp-action="FormEditEducationPage" asp-route-id="@edu.EducationId">Editar</a>
                            <form asp-controller="Education" asp-action="DeleteEducation" method="post" class="mb-0">
                                <input type="hidden" name="id" value="@edu.EducationId" />
                                <button type="button" class="btn btn-primary" onclick="confirmDelete('@edu.EducationId', '@Url.Action("DeleteEducation", "Education")')">Eliminar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
        <br />
    }

    @if (Model.WorkExperiences != null)
    {
        <div class="card container " style="padding:12px; border-radius: 10px; background-color: #F5F5F5;">
            <div class="d-flex justify-content-between align-items-center mb-2 mt-4">
                <h1 style="margin-left: 20px;">Experiencia Laboral💼</h1>
                <a class="btn btn-primary" style="margin-right:15px;" asp-area="" asp-controller="WorkExperience" asp-action="FormNewExperiencePage">Añadir</a>
            </div>
            @foreach (WorkExperience we in Model.WorkExperiences)
            {
                <div class="card row p-5 m-3" style=" border-radius: 10px;">
                    <div class="d-flex flex-column flex-md-row align-items-center">
                        <!-- Contenedor para el título y la descripción -->
                        <div class="flex-grow-1 mb-3 mb-md-0">
                            <h3 style="color: #1f4d78;" class="mb-0">Nombre de la empresa: @we.CompanyName sadafafasfasffsafasfas</h3>
                            <br />
                            <h5 class="mb-0">Descripción: @we.Description</h5>
                            <br />
                            <p class="mb-0">Duración: De @we.StartDate.ToString("yyyy-MM-dd") hasta @we.EndDate.ToString("yyyy-MM-dd")</p>
                        </div>

                        <!-- Contenedor para los botones -->
                        <div class="ms-auto d-flex align-items-center">
                            <a class="btn btn-primary me-2" asp-area="" asp-controller="WorkExperience" asp-action="FormEditExperiencePage" asp-route-id="@we.WorkExperienceId">Editar</a>
                            <form asp-controller="WorkExperience" asp-action="DeleteExperience" method="post" class="mb-0">
                                <input type="hidden" name="id" value="@we.WorkExperienceId" />
                                <button type="button" class="btn btn-primary" onclick="confirmDelete('@we.WorkExperienceId', '@Url.Action("DeleteExperience", "WorkExperience")')">Eliminar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@if (Model.RoleName == "Empresa")
{
    <script src="~/js/editCompany.js"></script>
    <div class="container mt-2">
        <form action="~/Profile/UpdateUserPersonalData" method="post">
            <div class="card p-3 position-relative">
                <!-- Botón Editar -->
                <button id="editButton" type="button" class="btn btn-primary position-absolute" style="top: 20px; right: 20px;" onclick="showEditOptions()">
                    Editar
                </button>

                <!-- Botones Confirmar y Cancelar -->
                <div id="editOptions" class="d-none position-absolute" style="top: 20px; right: 20px;">
                    <button type="button" class="btn btn-primary me-2" onclick="confirmEdit()">Confirmar</button>
                    <button type="button" class="btn btn-secondary" onclick="cancelEdit()">Cancelar</button>
                </div>

                <div class="row mt-5">
                    <h1>Acerca de nosotros</h1>

                    <!-- Sección Nombre Empresa -->
                    <h3>Nombre Empresa</h3>
                    <div id="nameSection">
                        <p class="d-none">@Model.Company.Name</p>
                        <input id="nameInput" type="text" class="form-control d-none" value="@Model.Company.Name" />
                    </div>

                    <!-- Sección Descripción -->
                    <h3>Descripción</h3>
                    <br />
                    <div id="descriptionSection">
                        <p class="d-none">@Model.Company.Description</p>
                        <textarea id="descriptionInput" class="form-control d-none" rows="3">@Model.Company.Description</textarea>
                    </div>

                    <br />
                    <h3>Tamaño Empresa</h3>
                    <div id="sizeSection">
                        <p class="d-none">@Model.Company.Size</p>
                        <input id="sizeInput" type="text" class="form-control d-none" value="@Model.Company.Size" />
                    </div>

                    <br />
                    <h3>Ubicación</h3>
                    <div id="locationSection">
                        <p class="d-none">@Model.Company.Location</p>
                        <input id="locationInput" type="text" class="form-control d-none" value="@Model.Company.Location" />
                    </div>

                    <br />
                    <h3>Enlace de la empresa</h3>
                    <div id="websiteSection">
                        <p class="d-none">@Model.Company.WebsiteUrl</p>
                        <input id="websiteInput" type="text" class="form-control d-none" value="@Model.Company.WebsiteUrl" />
                    </div>

                    <div class="container">
                        <div class="row">
                            <div class="col">
                                <h3>Numero de Empleados</h3>
                                <div id="employeeCountSection">
                                    <p class="d-none">@Model.Company.Size</p>
                                    <input id="employeeCountInput" type="text" class="form-control d-none" value="@Model.Company.Size" />
                                </div>
                            </div>
                            <div class="col">
                                <h3>Año Fundación de empresa</h3>
                                <div id="foundedYearSection">
                                    <p class="d-none">@Model.Company.FoundedYear</p>
                                    <input id="foundedYearInput" type="text" class="form-control d-none" value="@Model.Company.FoundedYear" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <h3>Beneficios Complementarios</h3>
                    @foreach (var benefit in Model.Company.CompensationBenefits)
                    {
                        <h1>@benefit.BenefitType</h1>
                        <h1>@benefit.Description</h1>
                    }
                </div>
            </div>
        </form>
    </div>

}

<!-- Bootstrap Modal for Confirmation -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                ¿Estás seguro de que deseas eliminar este elemento? Esta acción no se puede deshacer.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="confirmDeleteForm" method="post" class="d-inline">
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="~/js/profile.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function confirmDelete(id, actionUrl) {
        // Set the form action URL and ID
        var form = document.getElementById('confirmDeleteForm');
        form.action = actionUrl;
        document.getElementById('deleteId').value = id;

        // Show the modal
        var myModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        myModal.show();
    }
</script>
