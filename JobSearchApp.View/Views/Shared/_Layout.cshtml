        <nav class="navbar navbar-expand-md navbar-dark fixed-top bg-dark">
            <div class="container-fluid">
                <a style="color:white;" class="navbar-brand" asp-area="" asp-controller="Home" asp-action="HomePage">Swipe4Work</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (Context.Session.GetString("userId") == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="HomePage">Inicio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="InformationPage">Información</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="TeamDeveloperPage">Equipo</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="HomeLoggedPage">Inicio</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        @if (Context.Session.GetString("userId") == null)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <a id="contactLink" class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="ContactFormPage">Contacto</a>
                            </li>
                            <li class="nav-item d-flex align-items-center">
                                <a class="nav-link btn btn-primary text-white" asp-area="" asp-controller="Auth" asp-action="LoginPage">Iniciar Sesión</a>
                            </li>
                        }
                        else if (Context.Session.GetString("userId") != null)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <div class="dropdown">
                                    <a class="d-flex align-items-center text-decoration-none" href="#" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                                        <img style="border-radius: 1200px; height:50px; margin-left: 10px;" src="~/lib/img/perifl-icon.jpg" alt="Perfil" />
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownUser">
                                        <li><a class="dropdown-item" text-white" asp-area="" asp-controller="Profile" asp-action="ProfileOwnerUserPage">Mi Perfil</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form action="~/Auth/LogOut" method="post">
                                                <button type="submit" class="dropdown-item">Cerrar Sessión</button>
                                            </form>
                                        </li>
