                                            </svg>
                                        </a>
                                    </li>
                                    <li style="list-style-type: none;">
                                        <a href="https://facebook.com" target="_blank" class="social-icon">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
                                                <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951" />
                                            </svg>
                                        </a>
                                    </li>
                                    <li style="list-style-type: none;">
                                        <a href="https://linkedin.com" target="_blank" class="social-icon">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-linkedin" viewBox="0 0 16 16">
                                                <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z" />
                                            </svg>
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Third column: Right-aligned -->
                            <div class="col-md-4 d-flex flex-column align-items-end">
                                <ul class="list-unstyled footer-links mb-0">
                                    <li><a href="@Url.Action("ContactFormPage", "Home")">CONTACTANOS</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>


                <hr class="mb-4" />

                <section class="">
                    <div class="text-center footer-links">
                        <a href="#">Preguntas frecuentes</a> /
                        <a href="#">Consejos de seguridad</a> /
                        <a href="#">Condiciones</a>
                    </div>
                </section>

                <hr class="mb-4" />
            }
            else
            {
                <!-- Footer for logged-in users -->
                <section class="">
                    <div class="row">
                        <div class="col-lg-4 col-md-6 mb-4 mb-md-0">
                            <h5 class="text-uppercase">TU CUENTA</h5>
                            <ul class="list-unstyled footer-links">
                                <li><a href="@Url.Action("ProfileOwnerUserPage", "Profile")">Perfil</a></li>
                                <li><a href="#">Configuración</a></li>
                                <li>
                                    <form action="~/Auth/LogOut" method="post" class="mb-0">
                                        <button type="submit" class="btn btn-link text-white p-0" style="font-size: 1rem; border: none; background: none; padding: 0; margin: 0; text-decoration: none; transition: text-decoration 0.3s;">
                                            <span style="text-decoration: none;">Cerrar Sesión</span>
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-4 d-flex justify-content-center align-items-center">
                            <img src="~/lib/img/perifl-icon.jpg" alt="Profile" class="img-fluid rounded-circle" style="width: 80px;">
                        </div>
                        <div class="col-md-4">
                            <h5 class="text-uppercase">DANOS TU FEEDBACK</h5>
                            <ul class="list-unstyled footer-links">
                                <li><a href="#">Enviar feedback</a></li>
                            </ul>
                        </div>
                    </div>
                </section>

                <hr class="mb-4" />

                <section class="">
                    <div class="text-center footer-links">
                        <a href="#">Preguntas frecuentes</a> /
                        <a href="#">Consejos de seguridad</a> /
                        <a href="#">Condiciones</a>
                    </div>
                </section>

                <hr class="mb-4" />
            }
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/basicCarrusel.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
