<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobSearchApp.View</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/JobSearchApp.View.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav style="background-color: #1F4D78;" class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @if (ViewBag.Role == "Admin")
                {
                    <a style="color:white;" class="navbar-brand" asp-area="" asp-controller="Home" asp-action="HomePage">Swipe4Work</a>
                }
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="HomePage">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="InformationPage">Información</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="TeamDeveloperPage">Equipo</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="ContactFormPage">Contacto</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-primary text-white" asp-area="" asp-controller="Auth" asp-action="LoginPage">Iniciar Sessión</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center text-lg-start text-white"
            style="background-color: #1f4d78">
        <div class="container-fluid p-4 pb-0">
            <section class="">
                <div class="row">
                    <div class="col-lg-4 col-md-6 mb-4 mb-md-0">
                        <h5 class="text-uppercase">TU CUENTA</h5>
                        <ul class="list-unstyled footer-links">
                            <li><a href="#">Perfil</a></li>
                            <li><a href="#">Configuración</a></li>
                            <li><a href="#">Cerrar Sesión</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4 d-flex justify-content-center align-items-center">
                        <img src="path/to/image.png" alt="Profile" class="img-fluid rounded-circle" style="width: 80px;">
                    </div>
                    <div class="col-md-4">
                        <h5 class="text-uppercase">DANOS TU FEEDBACK</h5>
                        <ul class="list-unstyled footer-links">
                            <li><a href="#">Enviar feedback</a></li>
                        </ul>
                    </div>
                </div>
            </section>

            <hr class="mb-4" />

            <section class="">
                <div class="text-center footer-links">
                    <a href="#">Preguntas frecuentes</a> /
                    <a href="#">Consejos de seguridad</a> /
                    <a href="#">Condiciones</a>
                </div>
            </section>

            <hr class="mb-4" />
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
