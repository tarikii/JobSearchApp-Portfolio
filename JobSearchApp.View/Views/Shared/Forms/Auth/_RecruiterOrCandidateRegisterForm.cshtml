@using JobSearchApp.BusinessLogic.DTOs
<br />

<input type="hidden" name="role" value="@ViewBag.Role" />

<div class="name-input">
    <input class="form-control" type="text" name="FirstName" class="validate-input" placeholder="Nombre"/>
    <span class="error-message"></span>
</div><br />

<div class="name-input">
    <input class="form-control" type="text" name="LastName" class="validate-input" placeholder="Apellido" />
    <span class="error-message"></span>
</div>
<br />


<div class="name-input">
    <input class="form-control" type="text" name="Email" class="validate-input" placeholder="Correo" />
    <span class="error-message"></span>
</div>
<br />

<div class="name-input">
    <input class="form-control" type="text" name="UserName" class="validate-input" placeholder="Nombre Usuario" />
    <span class="error-message"></span>
</div>
<br />

<div class="name-input">
    <input class="form-control" type="text" name="PasswordHash" class="validate-input" placeholder="Contraseña" />
    <span class="error-message"></span>
</div>
<br />

<div class="name-input">
    <input class="form-control" type="text" class="validate-input" placeholder="Confirmar Contraseña" />
    <span class="error-message"></span>
</div>
<br />

@if (ViewBag.Role == "recruiter")
{
    <select class="form-select" aria-label="Default select example" name="CompanyId">
        <option>Actualmente estoy desempleado</option>
        @foreach (CompanyDto company in Model)
        {
            <option value="@company.CompanyId">@company.Name</option>
        }
    </select>
}

<div class="submit-button">
    <button type="submit">Registrarse</button>
</div>
