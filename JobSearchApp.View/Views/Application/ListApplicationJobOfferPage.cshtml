@using JobSearchApp.BusinessLogic.DTOs

@model IEnumerable<ApplicationDto>

<h1>Mis Postulaciones</h1>

<hr />

@if (Model.Count() != 0)
{
    @foreach (ApplicationDto a in Model)
    {
        <h1>@a.JobTitle</h1>
        <h3>@a.ApplicationDate</h3>
        <h3>@a.JobOffer.Description</h3><br />
        <a class="btn btn-primary" asp-area="" asp-controller="Feedback" asp-action="ViewFeedbackCandidatePage" asp-route-id="@a.ApplicationId">Ver Feedback</a>
        <hr />
    }
}
else
{
    <h1>Postulate a una oferta</h1>
}